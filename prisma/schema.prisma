// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
    output   = "../generated/prisma"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum UserPreset {
    HIGHSCHOOL
    COLLEGE
    UNIVERSITY
}

model Post {
    id        Int      @id @default(autoincrement())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    createdBy   User   @relation(fields: [createdById], references: [id])
    createdById String

    @@index([name])
}

model Account {
    id                       String  @id @default(cuid())
    userId                   String
    type                     String
    provider                 String
    providerAccountId        String
    refresh_token            String?
    access_token             String?
    expires_at               Int?
    token_type               String?
    scope                    String?
    id_token                 String?
    session_state            String?
    user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    refresh_token_expires_in Int?

    @@unique([provider, providerAccountId])
}

model Session {
    id           String   @id @default(cuid())
    sessionToken String   @unique
    userId       String
    expires      DateTime
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
    id            String    @id @default(cuid())
    name          String?
    email         String?   @unique
    emailVerified DateTime?
    image         String?
    password      String?
    learningStyle String?   @default("reading")
    autoAdapt     Boolean   @default(false)
    // Customization fields
    theme         String?   @default("light")
    accentColor   String?   @default("blue")
    fontSize      String?   @default("medium")
    compactMode   Boolean   @default(false)
    defaultNoteFormat String? @default("summary")
    autoSaveNotes Boolean   @default(true)
    emailNotifications Boolean @default(true)
    lastActive    DateTime?
    studyStreak   Int       @default(0)
    battleXp      Int       @default(0)
    battleWinStreak Int     @default(0)
    soloSessionsCompleted Int @default(0)
    battleAchievements String[] @default([])
    preset        UserPreset  @default(HIGHSCHOOL)
    presetSet     Boolean     @default(false)
    // Relations
    accounts      Account[]
    sessions      Session[]
    posts         Post[]
    notes         Note[]
    folders       Folder[]
    citations     Citation[]
    exams         Exam[]
    scanHistories ScanHistory[]
    examPredictions ExamPrediction[]
    hostedBattles Battle[] @relation("BattleHost")
    joinedBattles Battle[] @relation("BattleOpponent")
    battleParticipants BattleParticipant[]
    battleResults BattleResult[]
    createdStudyGroups StudyGroup[] @relation("StudyGroupCreator")
    studyGroupMemberships StudyGroupMember[]
    groupMessages GroupMessage[]
    sharedGroupNotes GroupSharedNote[] @relation("SharedNoteOwner")
    groupNoteComments GroupSharedNoteComment[]
    createdGroupFlashcards GroupFlashcard[]
    groupQuizRoundsStarted GroupQuizRound[] @relation("QuizRoundStarter")
    groupQuizSubmissions GroupQuizSubmission[]
    groupResourcesShared GroupResource[] @relation("ResourceSharer")
    groupSchedulesCreated GroupScheduleItem[] @relation("ScheduleCreator")
    groupStats GroupMemberStats[]
    hostedPomodoroTimers GroupPomodoroTimer[] @relation("PomodoroHost")
    pinnedGroupMessages GroupPinnedMessage[]
    conceptConnections ConceptConnection[]
    learningStyleResults LearningStyleResult[]
    conceptWebs ConceptWeb[]
    flashcardDecks FlashcardDeck[]
    novaStats NovaStats?
    hostedRooms StudyRoom[] @relation("RoomHost")
    roomMemberships RoomMember[]
    pdfDocuments PDFDocument[]
    annotations  Annotation[]
    focusSessions FocusSession[]
    feynmanSessions FeynmanSession[]
    studyPlans   StudyPlan[]
    calendarEvents CalendarEvent[]
    podcasts     Podcast[]
    diagrams     Diagram[]
    curriculumProgress OntarioCurriculumProgress[]
    wellnessEntries      WellnessEntry[]
    confidenceRatings    ConfidenceRating[]
    narrativeMemories    NarrativeMemory[]
    debateSessions       DebateSession[]
    interleavingSessions InterleavingSession[]
}

model OntarioCurriculumCourse {
    id          String   @id @default(cuid())
    code        String   @unique
    title       String
    grade       Int
    subject     String
    category    String   @default("General")
    type        String   @default("Open")
    destination String
    description String   @db.Text
    keywords    String[] @default([])
    isSeeded    Boolean  @default(false)
    seededAt    DateTime?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    units       OntarioCurriculumUnit[]
    progress    OntarioCurriculumProgress[]

    @@index([grade])
    @@index([subject])
    @@index([destination])
}

model OntarioCurriculumUnit {
    id          String   @id @default(cuid())
    courseId    String
    code        String
    title       String
    description String   @db.Text
    weight      Int      @default(0)
    orderIndex  Int      @default(0)
    createdAt   DateTime @default(now())

    course       OntarioCurriculumCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)
    expectations OntarioCurriculumExpectation[]

    @@unique([courseId, code])
    @@index([courseId])
    @@index([orderIndex])
}

model OntarioCurriculumExpectation {
    id          String   @id @default(cuid())
    unitId      String
    code        String
    title       String
    description String   @db.Text
    strand      String
    createdAt   DateTime @default(now())

    unit OntarioCurriculumUnit @relation(fields: [unitId], references: [id], onDelete: Cascade)

    @@unique([unitId, code])
    @@index([unitId])
    @@index([strand])
}

model OntarioCurriculumProgress {
    id               String   @id @default(cuid())
    userId           String
    courseId         String
    completedUnits   String[] @default([])
    completedExpectations String[] @default([])
    confidence       Int      @default(0)
    lastStudiedAt    DateTime?
    createdAt        DateTime @default(now())
    updatedAt        DateTime @updatedAt

    user   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
    course OntarioCurriculumCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

    @@unique([userId, courseId])
    @@index([userId])
    @@index([courseId])
}

model VerificationToken {
    identifier String
    token      String   @unique
    expires    DateTime

    @@unique([identifier, token])
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  format    String
    tags      String[] @default([])
    isPinned  Boolean  @default(false)
    lastViewedAt DateTime?
    isShared  Boolean  @default(false)
    folderId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    folder    Folder?  @relation(fields: [folderId], references: [id], onDelete: SetNull)
        sharedInGroups GroupSharedNote[]

  @@index([createdAt])
  @@index([userId])
    @@index([folderId])
}

model FeynmanSession {
    id            String   @id @default(cuid())
    userId        String
    concept       String
    explanation   String   @db.Text
    score         Int
    gradeLabel    String
    feedback      Json
    attemptNumber Int      @default(1)
    createdAt     DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([createdAt])
}

model StudyPlan {
    id        String   @id @default(cuid())
    userId    String
    weekStart DateTime
    subjects  String[]
    plan      Json
    createdAt DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([weekStart])
    @@index([createdAt])
}

model CalendarEvent {
    id          String   @id @default(cuid())
    userId      String
    title       String
    date        DateTime
    endDate     DateTime?
    type        String   @default("deadline")
    color       String   @default("#f97316")
    description String?
    completed   Boolean  @default(false)
    createdAt   DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([date])
    @@index([createdAt])
}

model Podcast {
    id         String   @id @default(cuid())
    userId     String
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    title      String
    sourceText String   @db.Text
    script     Json
    topic      String
    createdAt  DateTime @default(now())

    @@index([userId])
    @@index([createdAt])
}

model Diagram {
    id          String   @id @default(cuid())
    userId      String
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    title       String
    type        String
    sourceText  String   @db.Text
    diagramData Json
    createdAt   DateTime @default(now())

    @@index([userId])
    @@index([createdAt])
}

model Folder {
    id        String   @id @default(cuid())
    name      String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    userId    String
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    notes     Note[]

    @@index([userId])
}

model Citation {
    id          String   @id @default(cuid())
    author      String
    title       String
    publication String?
    date        String?
    url         String?
    pages       String?
    format      String
    createdAt   DateTime @default(now())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([createdAt])
}

model ExamPrediction {
    id              String   @id @default(cuid())
    examType        String
    uploadedContent String   @db.Text
    syllabusContent String?  @db.Text
    predictions     Json
    analytics       Json?
    // Smart forecast fields
    subject         String?
    examDate        DateTime?
    predictedScore  Float?
    confidence      Float?
    factors         Json?
    createdAt       DateTime @default(now())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([createdAt])
}

model Battle {
    id             String   @id @default(cuid())
    code           String   @unique
    noteId         String?
    title          String?
    status         String   @default("waiting")
    questionCount  Int      @default(10)
    mode           String   @default("pvp")
    subject        String?
    metadata       Json?
    questions      Json
    hostScore      Int      @default(0)
    opponentScore  Int      @default(0)
    hostAnsweredAt DateTime?
    opponentAnsweredAt DateTime?
    startedAt      DateTime?
    completedAt    DateTime?
    createdAt      DateTime @default(now())

    hostId     String
    opponentId String?

    host     User  @relation("BattleHost", fields: [hostId], references: [id], onDelete: Cascade)
    opponent User? @relation("BattleOpponent", fields: [opponentId], references: [id], onDelete: SetNull)

    battleQuestions BattleQuestion[]
    participants BattleParticipant[]
    result       BattleResult?

    @@index([hostId])
    @@index([opponentId])
    @@index([status])
    @@index([createdAt])
}

model BattleQuestion {
    id            String  @id @default(cuid())
    battleId      String
    question      String  @db.Text
    options       Json?
    correctAnswer String
    points        Int     @default(10)
    orderIndex    Int

    battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)

    @@index([battleId])
}

model BattleParticipant {
    id             String   @id @default(cuid())
    battleId       String
    userId         String
    answers        Json?
    score          Int      @default(0)
    correctCount   Int      @default(0)
    totalAnswered  Int      @default(0)
    joinedAt       DateTime @default(now())

    battle Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([battleId, userId])
    @@index([userId])
}

model BattleResult {
    id        String   @id @default(cuid())
    battleId  String   @unique
    winnerId  String?
    scores    Json
    duration  Int
    createdAt DateTime @default(now())

    battle  Battle @relation(fields: [battleId], references: [id], onDelete: Cascade)
    winner  User?  @relation(fields: [winnerId], references: [id], onDelete: SetNull)

    @@index([winnerId])
}

model StudyGroup {
    id        String   @id @default(cuid())
    name      String
    topic     String?
    inviteCode String  @unique
    isPublic  Boolean  @default(false)
    streakCount Int    @default(0)
    lastActiveAt DateTime?
    weeklyResetAt DateTime?
    settings Json?
    createdAt DateTime @default(now())

    creatorId String
    creator   User   @relation("StudyGroupCreator", fields: [creatorId], references: [id], onDelete: Cascade)

    members  StudyGroupMember[]
    messages GroupMessage[]
    sessions GroupSession[]
    sharedNotes GroupSharedNote[]
    flashcards GroupFlashcard[]
    quizRounds GroupQuizRound[]
    scheduleItems GroupScheduleItem[]
    resources GroupResource[]
    leaderboardStats GroupMemberStats[]
    pomodoroTimer GroupPomodoroTimer?
    pinnedMessages GroupPinnedMessage[]

    @@index([creatorId])
}

model StudyGroupMember {
    id        String   @id @default(cuid())
    groupId   String
    userId    String
    role      String   @default("member")
    lastSeenAt DateTime?
    joinedAt  DateTime @default(now())

    group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
    user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([groupId, userId])
    @@index([userId])
}

model GroupMessage {
    id        String   @id @default(cuid())
    groupId   String
    userId    String?
    message   String   @db.Text
    isAI      Boolean  @default(false)
    metadata  Json?
    timestamp DateTime @default(now())

    group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
    user  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
    pinnedInGroups GroupPinnedMessage[]

    @@index([groupId])
    @@index([timestamp])
}

model GroupSession {
    id        String   @id @default(cuid())
    groupId   String
    summary   String   @db.Text
    duration  Int
    topics    Json?
    createdAt DateTime @default(now())

    group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

    @@index([groupId])
}

model GroupSharedNote {
    id         String   @id @default(cuid())
    groupId    String
    noteId     String
    sharedById String
    pinned     Boolean  @default(false)
    createdAt  DateTime @default(now())

    group    StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
    note     Note       @relation(fields: [noteId], references: [id], onDelete: Cascade)
    sharedBy User       @relation("SharedNoteOwner", fields: [sharedById], references: [id], onDelete: Cascade)
    comments GroupSharedNoteComment[]

    @@unique([groupId, noteId])
    @@index([groupId])
    @@index([sharedById])
}

model GroupSharedNoteComment {
    id         String   @id @default(cuid())
    sharedNoteId String
    userId     String
    comment    String   @db.Text
    createdAt  DateTime @default(now())

    sharedNote GroupSharedNote @relation(fields: [sharedNoteId], references: [id], onDelete: Cascade)
    user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([sharedNoteId])
    @@index([userId])
}

model GroupFlashcard {
    id         String   @id @default(cuid())
    groupId    String
    creatorId  String
    front      String   @db.Text
    back       String   @db.Text
    knownBy    String[] @default([])
    learningBy String[] @default([])
    createdAt  DateTime @default(now())

    group   StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
    creator User       @relation(fields: [creatorId], references: [id], onDelete: Cascade)

    @@index([groupId])
    @@index([creatorId])
}

model GroupQuizRound {
    id                 String   @id @default(cuid())
    groupId            String
    startedById        String
    title              String
    status             String   @default("active")
    questions          Json
    currentQuestionIdx Int      @default(0)
    startedAt          DateTime @default(now())
    completedAt        DateTime?

    group      StudyGroup           @relation(fields: [groupId], references: [id], onDelete: Cascade)
    startedBy  User                 @relation("QuizRoundStarter", fields: [startedById], references: [id], onDelete: Cascade)
    submissions GroupQuizSubmission[]

    @@index([groupId])
    @@index([status])
}

model GroupQuizSubmission {
    id         String   @id @default(cuid())
    roundId    String
    userId     String
    answers    Json?
    score      Int      @default(0)
    completedAt DateTime?
    updatedAt  DateTime @updatedAt

    round GroupQuizRound @relation(fields: [roundId], references: [id], onDelete: Cascade)
    user  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([roundId, userId])
    @@index([userId])
}

model GroupScheduleItem {
    id         String   @id @default(cuid())
    groupId    String
    createdById String
    title      String
    startsAt   DateTime
    endsAt     DateTime?
    createdAt  DateTime @default(now())

    group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
    createdBy User       @relation("ScheduleCreator", fields: [createdById], references: [id], onDelete: Cascade)

    @@index([groupId])
    @@index([startsAt])
}

model GroupResource {
    id          String   @id @default(cuid())
    groupId     String
    sharedById  String
    type        String
    title       String
    url         String?
    noteId      String?
    metadata    Json?
    pinned      Boolean  @default(false)
    createdAt   DateTime @default(now())

    group    StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
    sharedBy User       @relation("ResourceSharer", fields: [sharedById], references: [id], onDelete: Cascade)

    @@index([groupId])
    @@index([sharedById])
    @@index([type])
}

model GroupMemberStats {
    id               String   @id @default(cuid())
    groupId          String
    userId           String
    weekKey          String
    notesSaved       Int      @default(0)
    quizzesCompleted Int      @default(0)
    messagesSent     Int      @default(0)
    weeklyScore      Int      @default(0)
    allTimeScore     Int      @default(0)
    updatedAt        DateTime @updatedAt

    group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
    user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([groupId, userId, weekKey])
    @@index([groupId])
    @@index([userId])
}

model GroupPomodoroTimer {
    id               String   @id @default(cuid())
    groupId          String   @unique
    hostId           String
    status           String   @default("paused")
    mode             String   @default("study")
    remainingSeconds Int      @default(1500)
    cycleCount       Int      @default(0)
    startedAt        DateTime?
    updatedAt        DateTime @updatedAt

    group StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
    host  User       @relation("PomodoroHost", fields: [hostId], references: [id], onDelete: Cascade)
}

model GroupPinnedMessage {
    id         String   @id @default(cuid())
    groupId    String
    messageId  String
    pinnedById String
    createdAt  DateTime @default(now())

    group    StudyGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
    message  GroupMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
    pinnedBy User         @relation(fields: [pinnedById], references: [id], onDelete: Cascade)

    @@index([groupId])
    @@index([messageId])
}

model ConceptConnection {
    id                    String   @id @default(cuid())
    note1Id               String
    note2Id               String
    concept1              String
    concept2              String
    connectionDescription String   @db.Text
    strength              String
    createdAt             DateTime @default(now())

    userId String
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([createdAt])
}

model LearningStyleResult {
    id                 String   @id @default(cuid())
    userId             String
    dominantStyle      String
    visualPercent      Int
    auditoryPercent    Int
    readingPercent     Int
    kinestheticPercent Int
    createdAt          DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([createdAt])
    @@index([dominantStyle])
}

model ConceptWeb {
    id         String   @id @default(cuid())
    userId     String
    title      String
    topic      String
    webData    Json
    shareToken String   @unique
    isShared   Boolean  @default(false)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([topic])
    @@index([createdAt])
}

model Exam {
    id               String    @id @default(cuid())
    userId           String
    subject          String
    examDate         DateTime
    board            String?
    difficulty       String?
    topics           String?
    studyPlan        String?
    resultRecorded   Boolean   @default(false)
    scorePercent     Float?
    gradeKU          Float?
    gradeThinking    Float?
    gradeComm        Float?
    gradeApp         Float?
    resultNotes      String?
    resultRecordedAt DateTime?
    createdAt        DateTime  @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([examDate])
    @@index([createdAt])
}

model ScanHistory {
    id         String   @id @default(cuid())
    userId     String
    confidence Int
    wordCount  Int
    subject    String?
    createdAt  DateTime @default(now())

    user User @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([createdAt])
}

model FlashcardDeck {
    id          String      @id @default(cuid())
    userId      String
    title       String
    subject     String
    description String?
    createdAt   DateTime    @default(now())
    updatedAt   DateTime    @updatedAt

    user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
    cards Flashcard[]

    @@index([userId])
    @@index([createdAt])
}

model Flashcard {
    id           String        @id @default(cuid())
    deckId       String
    front        String
    back         String
    easeFactor   Float         @default(2.5)
    interval     Int           @default(1)
    repetitions  Int           @default(0)
    nextReview   DateTime      @default(now())
    lastReviewed DateTime?
    createdAt    DateTime      @default(now())

    deck FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)
    confidenceRatings    ConfidenceRating[]

    @@index([deckId])
    @@index([nextReview])
    @@index([lastReviewed])
}

model NovaStats {
    id                String   @id @default(cuid())
    userId            String   @unique
    happiness         Int      @default(50)
    totalXP           Int      @default(0)
    level             Int      @default(1)
    streak            Int      @default(0)
    lastActiveDate    DateTime?
    notesGenerated    Int      @default(0)
    flashcardsStudied Int      @default(0)
    audioConverted    Int      @default(0)
    battlesWon        Int      @default(0)
    createdAt         DateTime @default(now())
    updatedAt         DateTime @updatedAt
    user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StudyRoom {
    id            String      @id @default(cuid())
    name          String
    subject       String
    description   String?
    hostId        String
    isPublic      Boolean     @default(true)
    maxMembers    Int         @default(10)
    pomodoroState Json?
    createdAt     DateTime    @default(now())
    updatedAt     DateTime    @updatedAt
    members       RoomMember[]
    host          User        @relation("RoomHost", fields: [hostId], references: [id])

    @@index([hostId])
    @@index([createdAt])
}

model RoomMember {
    id       String    @id @default(cuid())
    roomId   String
    userId   String
    joinedAt DateTime  @default(now())
    lastSeen DateTime  @default(now())
    status   String    @default("studying")
    room     StudyRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
    user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([roomId, userId])
    @@index([roomId])
    @@index([userId])
    @@index([lastSeen])
}

model PDFDocument {
    id          String       @id @default(cuid())
    userId      String
    title       String
    fileName    String
    fileSize    Int
    pageCount   Int
    blobUrl     String?
    createdAt   DateTime     @default(now())
    updatedAt   DateTime     @updatedAt
    user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
    annotations Annotation[]

    @@index([userId])
    @@index([updatedAt])
}

model Annotation {
    id        String      @id @default(cuid())
    docId     String
    userId    String
    page      Int
    type      String
    color     String
    text      String?
    note      String?
    rects     Json
    createdAt DateTime    @default(now())
    updatedAt DateTime    @updatedAt
    doc       PDFDocument @relation(fields: [docId], references: [id], onDelete: Cascade)
    user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([docId])
    @@index([userId])
    @@index([page])
}

model FocusSession {
    id           String   @id @default(cuid())
    userId       String
    goal         String?
    durationMins Int
    actualMins   Int?
    completed    Boolean  @default(false)
    abandoned    Boolean  @default(false)
    distractions Int      @default(0)
    startedAt    DateTime @default(now())
    endedAt      DateTime?
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@index([userId])
    @@index([startedAt])
}

model WellnessEntry {
    id           String   @id @default(cuid())
    userId       String
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    mood         Int
    energy       Int
    stress       Int
    notes        String?
    burnoutScore Float
    createdAt    DateTime @default(now())

    @@index([userId])
    @@index([createdAt])
}

model ConfidenceRating {
    id          String    @id @default(cuid())
    userId      String
    user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
    flashcardId String
    flashcard   Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
    rating      Int
    wasCorrect  Boolean
    createdAt   DateTime  @default(now())

    @@index([userId])
    @@index([flashcardId])
    @@index([createdAt])
}

model NarrativeMemory {
    id          String   @id @default(cuid())
    userId      String
    user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    noteId      String?
    sourceText  String   @db.Text
    narrative   String   @db.Text
    topic       String
    createdAt   DateTime @default(now())

    @@index([userId])
    @@index([topic])
    @@index([createdAt])
}

model DebateSession {
    id               String   @id @default(cuid())
    userId           String
    user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    topic            String
    forArguments     Json
    againstArguments Json
    verdict          String?
    createdAt        DateTime @default(now())

    @@index([userId])
    @@index([createdAt])
}

model InterleavingSession {
    id           String   @id @default(cuid())
    userId       String
    user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    subjects     String[]
    schedule     Json
    totalMinutes Int
    createdAt    DateTime @default(now())

    @@index([userId])
    @@index([createdAt])
}